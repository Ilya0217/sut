@startuml "Процесс 6: Проверка целостности связей"

title Процесс 6: Проверка целостности связей трассировки

actor "Пользователь" as User
participant "WebClient\n(TraceLinksView.vue)" as WC
participant "ApiGateway\n(tracelinks_api.cpp)" as AG
participant "TraceabilityService\n(traceability_service.cpp)" as TS
participant "Database\n(database.cpp)" as DB
participant "AuditService\n(audit_service.cpp)" as AS

User -> WC : Нажимает\n"Проверка целостности"
WC -> AG : POST /api/projects/{id}/\ntracelinks/integrity_check
AG -> AG : require_auth() → User
AG -> AG : user.can_run_integrity_check()\n(analyst/admin → OK)

AG -> TS : run_full_integrity_check(\nproject_id, user_id)

TS -> DB : get_links_for_project(project_id)
DB -> DB : SELECT tl.*, s.system_id,\ns.title, t.system_id, t.title\nFROM trace_links tl\nJOIN requirements s\nJOIN requirements t\nWHERE s.project_id = $1
DB --> TS : links[]

loop Для каждой связи
    TS -> DB : find_requirement_by_id(\nlink.source_req_id)
    DB --> TS : source_req

    TS -> DB : find_requirement_by_id(\nlink.target_req_id)
    DB --> TS : target_req

    alt Требование не найдено
        TS -> TS : issues.push_back(\n{link_id, "Требование не найдено"})
        TS -> DB : update_trace_link_status(\nlink_id, "NEEDS_REVIEW")
        DB -> DB : UPDATE trace_links\nSET status='NEEDS_REVIEW'
    else Требование удалено (is_deleted)
        TS -> TS : issues.push_back(\n{link_id, "Требование удалено"})
        TS -> DB : update_trace_link_status(\nlink_id, "NEEDS_REVIEW")
    else Требование изменено\n(version_at_link ≠ current version)
        TS -> TS : issues.push_back(\n{link_id, "Требование изменено\nпосле создания связи"})
        TS -> DB : update_trace_link_status(\nlink_id, "NEEDS_REVIEW")
    else Всё в порядке
        TS -> DB : update_trace_link_status(\nlink_id, "active")
        DB -> DB : UPDATE trace_links\nSET status='active'
    end
end

TS -> AS : log_action(user_id,\n"integrity_check", "trace_link")
AS -> DB : INSERT INTO audit_log

TS --> AG : issues[] (\n{link_id, reason} для каждой)
AG --> WC : JSON {\nissues_count: N,\nissues: [{link_id, reason}, ...]}

alt issues_count > 0
    WC --> User : "Найдено проблем: N"\n(badge bg-warning)
else
    WC --> User : "Нарушений не обнаружено"\n(badge bg-success)
end

@enduml
